{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake configure (debug-msvc)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "debug-msvc"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake configure (debug-gcc)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "debug-gcc"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake configure (debug-clang)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "debug-clang"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake build (windows-debug-msvc-x64)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "windows-debug-msvc-x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "CMake build (linux-debug-gcc-x64)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "linux-debug-gcc-x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "CMake build (macos-debug-clang-arm64-osx)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "macos-debug-clang-arm64-osx"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "CMake configure (release-msvc)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "release-msvc"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake configure (release-gcc)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "release-gcc"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake configure (release-clang)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset",
                "release-clang"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "CMake build (windows-release-msvc-x64)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "windows-release-msvc-x64",
                "--config",
                "Release"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "CMake build (linux-release-gcc-x64)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "linux-release-gcc-x64"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "CMake build (macos-release-clang-arm64-osx)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "--preset",
                "macos-release-clang-arm64-osx"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc"
        }
    ]
}
