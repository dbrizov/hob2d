body
{
    font-family: "JetBrains Mono";
}

#box
{
    position: absolute;
    left: 100px;
    top: 100px;
    width: 300px;
    height: 200px;
    padding: 20px;
    background-color: #3070ff;
}

#btn
{
    width: 200px;
    padding: 14px;
    background-color: #1f4fb0;
    color: #ffffff;
    font-size: 22px;
    text-align: center;
}

#btn:hover
{
    background-color: #6a9bff;
}
