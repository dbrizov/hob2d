{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Launch sandbox",
            "type": "shell",
            "args": [
                "--project",
                "sandbox"
            ],
            "windows": {
                "command": "${workspaceFolder}/../../build/debug/windows-msvc/Debug/hob2d.exe",
                "options": {
                    "cwd": "${workspaceFolder}/../../build/debug/windows-msvc/Debug"
                }
            },
            "linux": {
                "command": "${workspaceFolder}/../../build/debug/linux-gcc/Debug/hob2d",
                "options": {
                    "cwd": "${workspaceFolder}/../../build/debug/linux-gcc/Debug"
                }
            },
            "osx": {
                "command": "${workspaceFolder}/../../build/debug/macos-clang/Debug/hob2d",
                "options": {
                    "cwd": "${workspaceFolder}/../../build/debug/macos-clang/Debug"
                }
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "clear": true
            }
        }
    ]
}
