{
  "gamepad": {
    "stick_deadzone": 0.2,
    "trigger_deadzone": 0.1,
    "trigger_button_threshold": 0.5
  },
  "action_mappings": {
    "left": [
      "Left",
      "A",
      "Gamepad DpadLeft"
    ],
    "right": [
      "Right",
      "D",
      "Gamepad DpadRight"
    ],
    "up": [
      "Up",
      "W",
      "Gamepad DpadUp"
    ],
    "down": [
      "Down",
      "S",
      "Gamepad DpadDown"
    ],
    "submit": [
      "Return",
      "Gamepad A"
    ],
    "cancel": [
      "Escape",
      "Gamepad B"
    ],
    "slow_motion": [
      "Tab"
    ],
    "fire": [
      "Mouse Left",
      "Gamepad RightTrigger"
    ],
    "pause": [
      "Gamepad Start"
    ]
  },
  "axis_mappings": {
    "horizontal": {
      "acceleration": 10,
      "deceleration": 10,
      "positive": [
        "Right",
        "D"
      ],
      "negative": [
        "Left",
        "A"
      ],
      "analog": [
        {
          "source": "Gamepad LeftX",
          "scale": 1
        }
      ]
    },
    "vertical": {
      "acceleration": 10,
      "deceleration": 10,
      "positive": [
        "Up",
        "W"
      ],
      "negative": [
        "Down",
        "S"
      ],
      "analog": [
        {
          "source": "Gamepad LeftY",
          "scale": -1
        }
      ]
    },
    "aim_x": {
      "analog": [
        {
          "source": "Gamepad RightX",
          "scale": 1
        }
      ]
    },
    "aim_y": {
      "analog": [
        {
          "source": "Gamepad RightY",
          "scale": -1
        }
      ]
    }
  }
}
